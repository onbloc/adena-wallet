{
  "name": "adena-wallet",
  "version": "1.18.5",
  "description": "Adena Wallet",
  "license": "Adena License",
  "private": true,
  "scripts": {
    "setup": "pnpm install && pnpm allow-scripts",
    "develop": "pnpm --filter adena-extension build:dev",
    "build": "pnpm build:module && pnpm build:service && pnpm install",
    "build:module": "pnpm --filter adena-module --filter adena-torus-signin run build",
    "build:service": "pnpm --filter adena-extension build",
    "build:storybook": "pnpm --filter adena-extension build:storybook",
    "version:qa": "sh scripts/update-build-version.sh",
    "version:package": "sh scripts/update-package-version.sh",
    "tag": "sh scripts/create-tag.sh",
    "test": "jest --passWithNoTests"
  },
  "devDependencies": {
    "@babel/core": "7.23.9",
    "@babel/runtime": "7.23.9",
    "@lavamoat/allow-scripts": "3.0.3",
    "@lavamoat/preinstall-always-fail": "2.0.0",
    "babel-loader": "9.1.3",
    "eslint": "8.56.0",
    "file-loader": "6.2.0",
    "husky": "9.0.11",
    "jest": "29.7.0",
    "lint-staged": "15.4.3",
    "prettier": "3.2.5",
    "tsconfig-paths-webpack-plugin": "4.1.0",
    "typescript": "4.9.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "git add"
    ]
  },
  "lavamoat": {
    "allowScripts": {
      "@lavamoat/preinstall-always-fail": false,
      "@storybook/react>@storybook/docs-tools>@storybook/core-common>esbuild": false
    }
  },
  "pnpm": {
    "overrides": {
      "@storybook/react-docgen-typescript-plugin": "npm:react-docgen-typescript-plugin@1.0.5",
      "ws": "8.18.0",
      "@types/minimatch": "5.1.2"
    },
    "packageExtensions": {
      "@walletconnect/socket-transport@*": {
        "dependencies": {
          "ws": "8.18.0"
        }
      },
      "@walletconnect/jsonrpc-ws-connection@*": {
        "dependencies": {
          "ws": "8.18.0"
        }
      }
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19",
        "react-dom": "19"
      }
    },
    "patchedDependencies": {
      "recoil@0.7.7": "patches/recoil@0.7.7.patch"
    }
  },
  "packageManager": "pnpm@9.15.4"
}
