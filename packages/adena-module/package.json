{
  "name": "adena-module",
  "private": true,
  "version": "1.18.5",
  "description": "Adena's Wallet",
  "scripts": {
    "tsc": "tsc",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "build": "tsc --noEmit && tsdown",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/bn.js": "5.2.0",
    "@types/crypto-js": "4.2.2",
"@types/node": "^25.5.0",
    "@vitest/coverage-istanbul": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@cosmjs/ledger-amino": "0.38.1",
    "@gnolang/gno-js-client": "2.0.2",
    "@gnolang/tm2-js-client": "2.0.4",
    "@ledgerhq/hw-transport": "6.34.1",
    "@ledgerhq/hw-transport-mocker": "6.33.1",
    "@ledgerhq/hw-transport-webhid": "6.34.0",
    "@ledgerhq/hw-transport-webusb": "6.33.0",
    "@noble/hashes": "2.0.1",
    "bech32": "2.0.0",
    "bn.js": "5.2.3",
    "crypto-js": "4.2.0",
    "@noble/ciphers": "2.1.1",
    "@noble/curves": "2.0.1",
    "readonly-date": "1.0.0",
    "uuid": "13.0.0"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  }
}
